# Server Configuration
PORT=3000
NODE_ENV=production

# Database (Local SQLite)
DATABASE_PATH=./data/drop.db

# Turso Database (Optional - leave empty to use local SQLite)
# Get credentials from: https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# File Storage (Local)
STORAGE_PATH=./storage/files
MAX_FILE_SIZE=52428800

# S3 Storage (Optional - leave empty to use local storage)
# Works with AWS S3, MinIO, Backblaze B2, Cloudflare R2, etc.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Custom endpoint for S3-compatible services (optional)
S3_ENDPOINT=

# Authentication
# IMPORTANT: Change this password before first deployment!
DEFAULT_PASSWORD=changeme

BODY_SIZE_LIMIT=5G
